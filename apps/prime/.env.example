# Prime app environment variables
# Copy to .env.local and fill in real values.
# Production and staging secrets are managed via Cloudflare Pages secrets:
#   wrangler pages secret put <SECRET_NAME> --project-name prime
# See apps/prime/wrangler.toml for the full required-secrets list.

# ── Firebase (required) ────────────────────────────────────────────────────────
CF_FIREBASE_DATABASE_URL=
CF_FIREBASE_API_KEY=

# ── Firebase service account (required for server-side auth) ─────────────────
PRIME_FIREBASE_SERVICE_ACCOUNT_EMAIL=
PRIME_FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Staff owner gateway token (required) ──────────────────────────────────────
# Must be set to enable staff-owner-gated API routes (PRIME_ENABLE_STAFF_OWNER_ROUTES=true).
# Distinct from PRIME_ACTOR_CLAIMS_SECRET — do NOT reuse the same value.
PRIME_STAFF_OWNER_GATE_TOKEN=

# ── Actor claims HMAC secret (required for all 8 Prime mutation endpoints) ────
# HMAC-SHA256 key used to verify signed actor claims (x-prime-actor-claims header)
# sent by Reception. Must be ≥32 characters and MUST NOT equal PRIME_STAFF_OWNER_GATE_TOKEN.
#
# Generate a secure value:
#   openssl rand -base64 48 | tr -d '\n'
#
# Both Prime and Reception must share this value. Reception uses it to sign;
# Prime uses it to verify. See docs/plans/prime-outbound-auth-hardening/plan.md.
#
# Misconfiguration behaviour:
#   - Missing from Reception env → buildPrimeActorHeaders() throws before calling Prime;
#     Reception routes surface this as 502 via inboxApiErrorResponse (NOT a Prime-side 503).
#     This is the primary local-dev failure mode when the secret is absent.
#   - Missing or too short in Prime env → all mutation endpoints return 503 (claims-secret-not-configured)
#   - Equal to gateway token → validatePrimeActorClaimsConfig warns (or throws in production);
#     note: validatePrimeActorClaimsConfig() is currently not wired anywhere in apps/prime,
#     so misconfiguration is only surfaced at request-time, not at startup.
PRIME_ACTOR_CLAIMS_SECRET=

# ── KPI aggregation (optional) ────────────────────────────────────────────────
# Secret for the /api/kpi-aggregation endpoint. If absent, the endpoint is disabled.
PRIME_KPI_AGGREGATION_SECRET=

# ── Feature flags (optional) ──────────────────────────────────────────────────
# Set to "true" to enable staff-owner-gated routes (default: false)
PRIME_ENABLE_STAFF_OWNER_ROUTES=false
