{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@acme/platform-core": ["../../packages/platform-core/dist/index.d.ts"],
      "@acme/platform-core/*": ["../../packages/platform-core/dist/*"]
    },
    "types": ["node", "@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": [
    "functions/**/*.ts"
  ],
  "exclude": [
    "functions/**/__tests__/**",
    "functions/**/*.test.ts"
  ]
}
