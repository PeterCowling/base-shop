generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id    String @id
  /// @type {import("../../types/src/Shop").Shop}
  data  Json
  pages Page[]
  sections SectionTemplate[]
}

model Page {
  id     String @id @default(cuid())
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String
  slug   String
  data   Json
}

/// Reusable Sections (templates) curated per shop and inserted into pages
model SectionTemplate {
  id        String @id @default(cuid())
  shop      Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId    String
  label     String
  status    String // "draft" | "published"
  tags      Json?
  thumbnail String?
  data      Json

  @@index([shopId])
  @@index([shopId, status])
}

model RentalOrder {
  id                 String   @id
  shop               String
  sessionId          String
  deposit            Int
  expectedReturnDate String?
  startedAt          String
  returnedAt         String?
  refundedAt         String?
  damageFee          Int?
  customerId         String?
  riskLevel          String?
  riskScore          Int?
  flaggedForReview   Boolean? @default(false)
  trackingNumber     String?
  labelUrl           String?
  returnStatus       String?
  returnDueDate      String?
  returnReceivedAt   String?
  lateFeeCharged     Int?
  fulfilledAt        String?
  shippedAt          String?
  deliveredAt        String?
  cancelledAt        String?
  refundTotal        Int?
  status             String?
  currency           String?
  subtotalAmount     Int?
  taxAmount          Int?
  shippingAmount     Int?
  discountAmount     Int?
  totalAmount        Int?
  cartId             String?
  stripePaymentIntentId       String?
  stripeChargeId              String?
  stripeBalanceTransactionId  String?
  stripeCustomerId            String?

  /// CAT-01: Line items for this order with inventory allocation tracking.
  /// JSON array of OrderLineItem: { sku, productId?, variantAttributes, quantity, previousQuantity?, nextQuantity? }
  lineItems          Json?

  @@unique([shop, sessionId])
  @@unique([shop, trackingNumber])
  @@index([customerId])
}

model SubscriptionUsage {
  id         String @id @default(cuid())
  shop       String
  customerId String
  month      String
  shipments  Int    @default(0)

  @@unique([shop, customerId, month])
}

model CustomerProfile {
  customerId String @id
  name       String
  email      String
}

model CustomerIdentity {
  id                 String   @id @default(cuid())
  issuer             String
  subject            String
  internalCustomerId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([issuer, subject])
  @@unique([internalCustomerId])
  @@index([internalCustomerId])
}

model CustomerStripeMapping {
  id                 String   @id @default(cuid())
  internalCustomerId String
  stripeCustomerId   String
  environment        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([internalCustomerId, environment])
  @@unique([stripeCustomerId, environment])
  @@index([internalCustomerId])
}

model CustomerMfa {
  customerId String  @id
  secret     String
  enabled    Boolean @default(false)
}

model User {
  id                   String    @id
  email                String    @unique
  passwordHash         String
  role                 String
  resetToken           String?
  resetTokenExpiresAt  DateTime?
  emailVerified        Boolean   @default(false)
  stripeSubscriptionId String?
}

model InventoryItem {
  id                String   @id @default(cuid())
  shopId            String
  sku               String
  productId         String
  quantity          Int
  variantAttributes Json
  lowStockThreshold Int?
  wearCount         Int?
  wearAndTearLimit  Int?
  maintenanceCycle  Int?
  variantKey        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shopId, sku, variantKey])
  @@index([shopId])
  @@index([shopId, sku])
}

model ReturnLogistics {
  id   Int  @id
  data Json
}

model ReverseLogisticsEvent {
  id        String @id @default(cuid())
  shop      String
  sessionId String
  event     String
  createdAt String

  @@index([shop])
}

model Setting {
  shop String @id
  data Json
}

model SettingDiff {
  id        String @id @default(cuid())
  shop      String
  timestamp String
  diff      Json

  @@index([shop])
}

model StripeWebhookEvent {
  /// Stripe event id.
  id        String   @id
  shop      String
  type      String
  /// "processed" | "failed" (kept as string for backward-compatible evolution).
  status    String
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([status])
  @@index([updatedAt])
}

// ============================================================
// Central Inventory (LAUNCH-13b)
// Source of truth for inventory across all shops.
// Per-shop inventory is derived from central + routing rules.
// ============================================================

model CentralInventoryItem {
  id                String   @id @default(cuid())
  sku               String
  productId         String
  variantKey        String
  variantAttributes Json
  quantity          Int
  lowStockThreshold Int?
  wearCount         Int?
  wearAndTearLimit  Int?
  maintenanceCycle  Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  routings InventoryRouting[]

  @@unique([sku, variantKey])
  @@index([sku])
  @@index([productId])
}

model InventoryRouting {
  id                     String               @id @default(cuid())
  centralInventoryItemId String
  centralInventoryItem   CentralInventoryItem @relation(fields: [centralInventoryItemId], references: [id], onDelete: Cascade)
  shopId                 String
  /// Allocation mode: "all" routes all stock, "fixed" uses allocatedQuantity, "percentage" uses allocatedPercent
  allocationMode         String               @default("all")
  /// Fixed quantity allocated to this shop (when allocationMode = "fixed")
  allocatedQuantity      Int?
  /// Percentage of stock allocated to this shop (when allocationMode = "percentage")
  allocatedPercent       Int?
  /// Priority for allocation when stock is limited (lower = higher priority)
  priority               Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([centralInventoryItemId, shopId])
  @@index([shopId])
  @@index([centralInventoryItemId])
}

model InventoryHold {
  id          String    @id @default(cuid())
  shopId      String
  status      String    // "active" | "committed" | "released" | "expired"
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  committedAt DateTime?
  releasedAt  DateTime?
  expiredAt   DateTime?

  items InventoryHoldItem[]

  @@index([shopId])
  @@index([status])
  @@index([expiresAt])
}

model InventoryHoldItem {
  id                String        @id @default(cuid())
  holdId            String
  hold              InventoryHold @relation(fields: [holdId], references: [id], onDelete: Cascade)
  shopId            String
  sku               String
  productId         String
  variantKey        String
  variantAttributes Json
  quantity          Int

  @@index([holdId])
}

/// Per-item audit trail for stock adjustments and inflows.
/// Replaces JSONL file-based audit logs; Worker-safe (Prisma/PostgreSQL only).
model InventoryAuditEvent {
  id            String   @id @default(cuid())
  shopId        String
  sku           String
  variantKey    String
  type          String   // "adjustment" | "inflow"
  quantityDelta Int
  note          String?
  referenceId   String?  // idempotency key
  operatorId    String?
  createdAt     DateTime @default(now())

  @@index([shopId])
  @@index([shopId, sku])
  @@index([shopId, type])
  @@index([referenceId])
}

/// Product catalogue entry for all shops. Replaces JSON file-backed products.json.
/// Worker-safe (Prisma/PostgreSQL only). All shops share this model via shopId.
model Product {
  id               String   @id
  shopId           String
  sku              String
  title            Json
  description      Json
  media            Json
  price            Int
  currency         String
  status           String
  row_version      Int      @default(1)
  forSale          Boolean  @default(true)
  forRental        Boolean  @default(false)
  deposit          Int      @default(0)
  rentalTerms      String?
  dailyRate        Int?
  weeklyRate       Int?
  monthlyRate      Int?
  wearAndTearLimit Int?
  maintenanceCycle Int?
  availability     Json?
  materials        Json?
  dimensions       Json?
  weight           Json?
  publishShops     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shopId, sku])
  @@unique([shopId, id])
  @@index([shopId])
}

// ============================================================
// Payment Manager (payment-management-app)
// Centralised payment lifecycle management across all shops.
// ============================================================

/// Per-shop active payment provider selection and config.
model ShopPaymentConfig {
  id             String   @id @default(cuid())
  shopId         String   @unique
  /// "stripe" | "axerve" | "disabled"
  activeProvider String   @default("axerve")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  credentials ShopProviderCredential[]
  orders      Order[]
}

/// Encrypted payment provider credentials per shop and provider.
/// encryptedValue stores base64(<12-byte-IV><AES-256-GCM-ciphertext>).
model ShopProviderCredential {
  shopId         String
  /// "stripe" | "axerve"
  provider       String
  /// e.g. "apiKey", "shopLogin", "hmacSecret"
  credentialKey  String
  /// base64(<12-byte-IV><ciphertext>) — never plaintext
  encryptedValue String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  config ShopPaymentConfig @relation(fields: [shopId], references: [shopId], onDelete: Cascade)

  @@id([shopId, provider, credentialKey])
  @@index([shopId, provider])
}

/// Immutable audit trail for payment config changes (provider switches, credential updates).
model PaymentConfigAudit {
  id          Int      @id @default(autoincrement())
  shopId      String
  changedBy   String
  /// e.g. "activeProvider", "apiKey"
  field       String
  oldValue    String?
  newValue    String?
  changedAt   DateTime @default(now())

  @@index([shopId])
  @@index([changedAt])
}

/// Cross-portfolio order record. Written by storefront dual-write hooks (fire-and-forget).
model Order {
  id              String   @id @default(cuid())
  shopId          String
  /// "stripe" | "axerve"
  provider        String
  /// "pending" | "completed" | "failed" | "resolved"
  status          String   @default("pending")
  amountCents     Int
  currency        String   @default("EUR")
  customerEmail   String?
  /// Stripe payment_intent id or Axerve shopTransactionId
  providerOrderId String?
  /// JSON array of line items: [{productId, sku, qty, unitCents}]
  lineItemsJson   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  config  ShopPaymentConfig @relation(fields: [shopId], references: [shopId], onDelete: Restrict)
  refunds Refund[]

  @@index([shopId])
  @@index([createdAt])
  @@index([status])
}

/// Refund record per order. Written on every refund attempt (success or failure).
/// Invariant: shopId MUST equal the parent Order's shopId.
/// This is enforced at the application layer (refunds route derives shopId from the
/// fetched Order record only — never from user-supplied input).
model Refund {
  id               String   @id @default(cuid())
  orderId          String
  shopId           String
  /// "stripe" | "axerve"
  provider         String
  amountCents      Int
  /// "pending" | "succeeded" | "failed"
  status           String   @default("pending")
  /// operator email or "system"
  issuedBy         String
  /// Provider-assigned refund id (Stripe refund id or Axerve transaction id)
  providerRefundId String?
  errorMessage     String?
  /// Optional operator note or machine-caller reason supplied at refund time
  reason           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([shopId])
  @@index([createdAt])
}

// ============================================================
// Checkout Idempotency (caryina-runtime-state-workers-compat)
// Replaces fs-based idempotency store; Worker-safe (Prisma/Neon).
// ============================================================

/// Checkout attempt idempotency record.
/// One record per (shopId, idempotencyKey) pair.
/// Status values: "in_progress" | "finalizing" | "succeeded" | "failed" | "needs_review"
model CheckoutAttempt {
  id                      String    @id @default(cuid())
  shopId                  String
  idempotencyKey          String
  /// SHA-256 hash of the canonical checkout request body.
  requestHash             String
  /// "in_progress" | "finalizing" | "succeeded" | "failed" | "needs_review"
  status                  String
  acceptedLegalTerms      Boolean?
  acceptedLegalTermsAt    DateTime?
  /// "stripe" | "axerve"
  provider                String?
  shopTransactionId       String?
  holdId                  String?
  cartId                  String?
  lang                    String?
  buyerName               String?
  buyerEmail              String?
  paymentAttemptedAt      DateTime?
  stripeSessionId         String?
  stripeSessionExpiresAt  DateTime?
  stripePaymentIntentId   String?
  responseStatus          Int?
  /// JSON body returned to the buyer on terminal status (used for idempotent replay).
  responseBody            Json?
  errorCode               String?
  errorMessage            String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([shopId, idempotencyKey])
  @@index([shopId])
  @@index([status])
  @@index([updatedAt])
}

// ============================================================
// Cart Store (caryina-runtime-state-workers-compat)
// Replaces MemoryCartStore for Caryina; Worker-safe (Prisma/Neon).
// ============================================================

/// Ephemeral cart record.
/// cartId is generated by PrismaCartStore.createCart() and returned to the caller.
/// CartState (items map) stored as JSON. expiresAt enables background TTL cleanup.
model Cart {
  id        String   @id @default(cuid())
  /// JSON map of SKU -> cart item (matches CartState shape).
  items     Json     @default("{}")
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}
