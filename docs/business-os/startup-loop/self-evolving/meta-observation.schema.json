{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/business-os/startup-loop/self-evolving/meta-observation.schema.json",
  "title": "Self-Evolving Meta Observation",
  "type": "object",
  "required": [
    "schema_version",
    "observation_id",
    "observation_type",
    "timestamp",
    "business",
    "actor_type",
    "run_id",
    "session_id",
    "artifact_refs",
    "context_path",
    "hard_signature",
    "fingerprint_version",
    "detector_confidence",
    "severity",
    "inputs_hash",
    "outputs_hash",
    "toolchain_version",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "observation_id": { "type": "string", "minLength": 1 },
    "observation_type": {
      "type": "string",
      "enum": [
        "execution_event",
        "validation_failure",
        "operator_intervention",
        "routing_override",
        "metric_regression",
        "metric_plateau",
        "funnel_dropoff_detected",
        "experiment_result_observed",
        "customer_feedback_theme_recurring"
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "business": { "type": "string", "minLength": 1 },
    "actor_type": { "type": "string", "enum": ["operator", "agent", "automation"] },
    "run_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "skill_id": { "type": ["string", "null"] },
    "container_id": { "type": ["string", "null"] },
    "artifact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "context_path": { "type": "string", "minLength": 1 },
    "hard_signature": { "type": "string", "minLength": 1 },
    "soft_cluster_id": { "type": ["string", "null"] },
    "fingerprint_version": { "type": "string", "minLength": 1 },
    "detector_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "severity": { "type": "number", "minimum": 0, "maximum": 1 },
    "inputs_hash": { "type": "string", "minLength": 1 },
    "outputs_hash": { "type": "string", "minLength": 1 },
    "toolchain_version": { "type": "string", "minLength": 1 },
    "data_quality_status": {
      "type": ["string", "null"],
      "enum": ["ok", "degraded", "unknown", null]
    },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
