# Caryina - environment variables
# Copy to .env.local and fill in values (never commit .env.local)

# ============================================================
# Email delivery - Option A: Gmail SMTP (current v1 approach)
# ============================================================
# Required: tells sendSystemEmail which email provider to use.
# Set to any non-empty value (e.g. "gmail") to activate the Gmail path.
EMAIL_PROVIDER=gmail

# Gmail SMTP credentials (used by @acme/email sendEmail via nodemailer)
# Without these, sendSystemEmail silently simulates email delivery.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_PASS=your-gmail-app-password

# Merchant notification email for order and notify-me alerts
MERCHANT_NOTIFY_EMAIL=your-email@example.com

# ============================================================
# Email delivery - Option B: Resend (v2 upgrade path)
# ============================================================
# Uncomment and set RESEND_API_KEY to switch to Resend delivery.
# Requires EMAIL_PROVIDER=resend and a Resend account.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# ============================================================
# Payment provider selector
# ============================================================
PAYMENTS_PROVIDER=axerve # Set to axerve or stripe. When unset, Caryina defaults to axerve.

# ============================================================
# Axerve / GestPay payments
# ============================================================
AXERVE_SHOP_LOGIN=your-axerve-shop-login # Required when PAYMENTS_PROVIDER=axerve: shop login identifier from the Axerve merchant agreement.
AXERVE_API_KEY=your-axerve-api-key # Required when PAYMENTS_PROVIDER=axerve: API key from the Axerve merchant agreement.
# AXERVE_USE_MOCK=true # Optional dev-only: when true, all payment calls return a hardcoded success and do not hit Axerve; this takes priority over AXERVE_SANDBOX.
# AXERVE_SANDBOX=true # Optional test-only: routes SOAP calls to sandbox.gestpay.net instead of production; set AXERVE_SHOP_LOGIN and AXERVE_API_KEY to sandbox credentials from the Axerve merchant portal.
# Sandbox test note: AXERVE_USE_MOCK must be unset or removed, otherwise mock mode overrides sandbox mode.

# ============================================================
# Stripe payments
# ============================================================
# STRIPE_SECRET_KEY=sk_test_xxxxx # Required when PAYMENTS_PROVIDER=stripe.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx # Required when PAYMENTS_PROVIDER=stripe.
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx # Required when PAYMENTS_PROVIDER=stripe.

# ============================================================
# Checkout integrity / reconciliation
# ============================================================
# Required for authenticated cron endpoint:
#   GET /api/cron/checkout-reconciliation
# Configure as a Worker secret in production.
CRON_SECRET=replace-with-long-random-secret

# Optional safety valve for synchronous reconciliation on checkout exceptions.
# 1 = enabled (attempt stale-checkout reconciliation after hard failures)
# 0 or unset = disabled (default)
CARYINA_CHECKOUT_AUTO_RECONCILE=0

# ============================================================
# Payment Manager internal API integration
# ============================================================
# Shared secret for service-to-service calls from Payment Manager.
# Must match CARYINA_INTERNAL_TOKEN in apps/payment-manager/.env.local
# Configure as a Worker/Platform secret in production.
CARYINA_INTERNAL_TOKEN=

# Bearer token Caryina uses when proxying refund requests to Payment Manager.
# Must match CARYINA_PM_TOKEN in apps/payment-manager/.env.local
# Configure as a Worker/Platform secret in production.
CARYINA_PM_TOKEN=

# Payment Manager base URL for runtime provider config lookups (Phase 3).
# Set to the deployed PM Worker URL in production (e.g. https://payment-manager.example.workers.dev).
# When unset, Caryina falls back to PAYMENTS_PROVIDER env var.
PAYMENT_MANAGER_URL=

# Internal token Caryina uses to call PM's /api/internal/shop-config.
# Must match PAYMENT_MANAGER_INTERNAL_TOKEN in apps/payment-manager/.env.local
PAYMENT_MANAGER_INTERNAL_TOKEN=
