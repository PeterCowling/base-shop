{
  "name": "@apps/caryina",
  "private": true,
  "scripts": {
    "dev": "bash ../../scripts/dev/run-next-app.sh --port 3018",
    "prebuild": "pnpm --filter scripts startup-loop:materialize-site-content-payload -- --business HBAG --shop caryina --repo-root ../..",
    "build": "next build --webpack",
    "build:worker": "opennextjs-cloudflare build",
    "build:deps": "pnpm exec turbo run build --filter=@apps/caryina^...",
    "start": "next start -p 3018",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "typecheck": "bash ../../scripts/dev/run-next-app.sh --mode typecheck --port 3018 -- pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "bash ../../scripts/tests/run-governed-test.sh -- jest -- --config ./jest.config.cjs --passWithNoTests",
    "e2e": "pnpm run build:deps && pnpm exec playwright test --config ./playwright.config.ts",
    "e2e:smoke": "pnpm run build:deps && pnpm exec playwright test --config ./playwright.config.ts --grep @smoke",
    "validate:launch-media": "pnpm exec tsx ./scripts/validate-launch-media-contract.ts"
  },
  "dependencies": {
    "@acme/axerve": "workspace:*",
    "@acme/design-system": "workspace:*",
    "@acme/lib": "workspace:*",
    "@acme/next-config": "workspace:*",
    "@acme/platform-core": "workspace:*",
    "@acme/stripe": "workspace:*",
    "@acme/ui": "workspace:*",
    "@themes/base": "workspace:*",
    "@themes/caryina": "workspace:*",
    "next": "^16.1.6",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.16.5"
  }
}
