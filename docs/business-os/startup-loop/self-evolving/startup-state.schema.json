{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/business-os/startup-loop/self-evolving/startup-state.schema.json",
  "title": "Startup State System of Record",
  "type": "object",
  "required": [
    "schema_version",
    "startup_state_id",
    "business_id",
    "stage",
    "offer",
    "icp",
    "positioning",
    "brand",
    "stack",
    "analytics_stack",
    "channels_enabled",
    "credential_refs",
    "kpi_definitions",
    "asset_refs",
    "constraints",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "startup_state_id": { "type": "string", "minLength": 1 },
    "business_id": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "enum": ["prelaunch", "launched", "traction"] },
    "offer": { "type": "object" },
    "icp": { "type": "object" },
    "positioning": { "type": "object" },
    "brand": {
      "type": "object",
      "required": ["voice_tone", "do_rules", "dont_rules"],
      "properties": {
        "voice_tone": { "type": "string", "minLength": 1 },
        "do_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "dont_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "stack": {
      "type": "object",
      "required": ["website_platform", "repo_ref", "deploy_target"],
      "properties": {
        "website_platform": { "type": "string", "minLength": 1 },
        "repo_ref": { "type": "string", "minLength": 1 },
        "deploy_target": { "type": "string", "minLength": 1 }
      }
    },
    "analytics_stack": {
      "type": "object",
      "required": ["provider", "workspace_id", "event_schema_ref"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "workspace_id": { "type": "string", "minLength": 1 },
        "event_schema_ref": { "type": "string", "minLength": 1 }
      }
    },
    "channels_enabled": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["channel", "automation_allowed"],
        "properties": {
          "channel": { "type": "string", "minLength": 1 },
          "automation_allowed": { "type": "boolean" }
        }
      }
    },
    "credential_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "kpi_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "unit", "aggregation_method", "kind"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "unit": { "type": "string", "enum": ["ratio", "count", "currency", "seconds", "score"] },
          "aggregation_method": { "type": "string", "enum": ["mean", "median", "sum", "rate"] },
          "kind": { "type": "string", "enum": ["primary", "guardrail"] }
        }
      }
    },
    "asset_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "updated_at": { "type": "string", "format": "date-time" },
    "updated_by": { "type": "string", "minLength": 1 }
  }
}
