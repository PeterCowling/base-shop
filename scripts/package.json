{
  "name": "scripts",
  "private": true,
  "scripts": {
    "classify-deploy-change": "node --import tsx src/ci/classify-deploy-change.ts",
    "classify-paths": "node ci/path-classifier.cjs",
    "collect-workflow-metrics": "node --import tsx src/ci/collect-workflow-metrics.ts",
    "generate-stage-operator-views": "node --import tsx src/startup-loop/generate-stage-operator-views.ts && node --import tsx src/startup-loop/build/generate-build-summary.ts && node --import tsx src/startup-loop/build/generate-process-improvements.ts",
    "check-stage-operator-views": "node --import tsx src/startup-loop/generate-stage-operator-views.ts --check",
    "check-baselines-freshness": "node --import tsx src/startup-loop/baselines/baselines-freshness-cli.ts",
    "check-assessment-completion": "node --import tsx src/startup-loop/assessment/assessment-completion-cli.ts",
    "startup-loop:compile-website-content-packet": "node --import tsx src/startup-loop/website/compile-website-content-packet.ts",
    "validate-process-assignment": "node --import tsx src/startup-loop/diagnostics/validate-process-assignment.ts",
    "test": "cross-env JEST_FORCE_CJS=1 bash tests/run-governed-test.sh -- jest -- --config ./jest.config.cjs",
    "startup-loop:materialize-site-content-payload": "node --import tsx src/startup-loop/website/materialize-site-content-payload.ts",
    "startup-loop:lint-website-content-packet": "node --import tsx src/startup-loop/website/lint-website-content-packet.ts",
    "startup-loop:map-artifact-delta-to-website-backlog": "node --import tsx src/startup-loop/website/map-artifact-delta-to-website-backlog.ts",
    "startup-loop:website-iteration-throughput-report": "node --import tsx src/startup-loop/website/website-iteration-throughput-report.ts",
    "startup-loop:generate-process-improvements": "node --import tsx src/startup-loop/build/generate-process-improvements.ts",
    "startup-loop:self-evolving-report": "node --import tsx src/startup-loop/self-evolving/self-evolving-report.ts",
    "startup-loop:self-evolving-from-ideas": "node --import tsx src/startup-loop/self-evolving/self-evolving-from-ideas.ts",
    "check-process-improvements": "node --import tsx src/startup-loop/build/generate-process-improvements.ts --check",
    "startup-loop:lp-do-ideas-live-run": "node --import tsx src/startup-loop/ideas/lp-do-ideas-live-hook.ts --registry-path docs/business-os/startup-loop/ideas/standing-registry.json --queue-state-path docs/business-os/startup-loop/ideas/trial/queue-state.json --telemetry-path docs/business-os/startup-loop/ideas/trial/telemetry.jsonl",
    "startup-loop:lp-do-ideas-trial-run": "node --import tsx src/startup-loop/ideas/lp-do-ideas-live-hook.ts --registry-path docs/business-os/startup-loop/ideas/standing-registry.json --queue-state-path docs/business-os/startup-loop/ideas/trial/queue-state.json --telemetry-path docs/business-os/startup-loop/ideas/trial/telemetry.jsonl",
    "startup-loop:lp-do-ideas-build-commit-hook": "node --import tsx src/startup-loop/ideas/lp-do-ideas-build-commit-hook.ts",
    "startup-loop:lp-do-ideas-codebase-signals-bridge": "node --import tsx src/startup-loop/ideas/lp-do-ideas-codebase-signals-bridge.ts",
    "startup-loop:lp-do-ideas-agent-session-bridge": "node --import tsx src/startup-loop/ideas/lp-do-ideas-agent-session-bridge.ts",
    "startup-loop:self-evolving-from-build-output": "node --import tsx src/startup-loop/self-evolving/self-evolving-from-build-output.ts",
    "startup-loop:queue-state-canonicalize": "node --import tsx src/startup-loop/ideas/lp-do-ideas-queue-state-canonicalize.ts",
    "startup-loop:results-review-prefill": "node --import tsx src/startup-loop/build/lp-do-build-results-review-prefill.ts",
    "startup-loop:pattern-reflection-prefill": "node --import tsx src/startup-loop/build/lp-do-build-pattern-reflection-prefill.ts"
  },
  "dependencies": {
    "@acme/lib": "workspace:*",
    "js-yaml": "4.1.1"
  }
}
