#!/usr/bin/env bash
set -euo pipefail

# Agent git guard wrapper (argv-based).
#
# Policy is evaluated by a shared Node evaluator:
#   scripts/agents/evaluate-git-safety.mjs
#
# Canonical source: docs/git-safety.md (kernel fence)

wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="${BASESHOP_GUARD_REPO_ROOT:-}"

if [[ -z "$repo_root" ]]; then
  # This script lives inside the repo; prefer a fast path over invoking git.
  repo_root="$(cd "${wrapper_dir}/../.." && pwd)"
fi

real_git=""
IFS=":" read -r -a path_entries <<< "${PATH:-}"
for dir in "${path_entries[@]}"; do
  [[ -z "$dir" ]] && continue
  if [[ "$(cd "$dir" 2>/dev/null && pwd)" == "$wrapper_dir" ]]; then
    continue
  fi
  if [[ -x "${dir}/git" ]]; then
    real_git="${dir}/git"
    break
  fi
done

fail_closed_infrastructure() {
  local reason="$1"
  local retry_posture="$2"
  local next_step="$3"
  local anti_retry="$4"
  local escalation="$5"
  local exit_code="${6:-1}"

  echo "BLOCKED [fail-closed-infrastructure]: ${reason}" >&2
  echo "" >&2
  echo "Retry posture : ${retry_posture}" >&2
  echo "Next step     : ${next_step}" >&2
  echo "" >&2
  echo "Do not retry with:" >&2
  echo "  ${anti_retry}" >&2
  echo "" >&2
  echo "Escalation    : ${escalation}" >&2
  exit "${exit_code}"
}

if [[ -z "$real_git" ]]; then
  fail_closed_infrastructure \
    "real git binary not found on PATH (scripts/agent-bin/ skipped)" \
    "escalate-now" \
    "verify git is installed: run \`which git\` in a clean shell outside this repo" \
    "retrying this command will fail for the same reason until PATH is fixed" \
    "surface to operator; do not retry locally" \
    127
fi

evaluator="${repo_root}/scripts/agents/evaluate-git-safety.mjs"
policy_json="${repo_root}/.agents/safety/generated/git-safety-policy.json"
if [[ ! -f "$evaluator" ]]; then
  fail_closed_infrastructure \
    "git safety evaluator missing: ${evaluator}" \
    "escalate-now" \
    "scripts/agents/generate-git-safety-policy --write" \
    "retrying the git command without regenerating the evaluator will fail" \
    "surface to operator; do not retry locally" \
    1
fi
if [[ ! -f "$policy_json" ]]; then
  fail_closed_infrastructure \
    "git safety policy missing: ${policy_json}" \
    "escalate-now" \
    "scripts/agents/generate-git-safety-policy --write" \
    "retrying the git command without regenerating the policy will fail" \
    "surface to operator; do not retry locally" \
    1
fi

set +e
node "$evaluator" --policy "$policy_json" -- "$@"
eval_status="$?"
set -e

if [[ "$eval_status" -ne 0 ]]; then
  exit "$eval_status"
fi

exec "$real_git" "$@"
