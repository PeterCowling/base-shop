{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@acme/platform-core": ["../../packages/platform-core/dist/index.d.ts"],
      "@acme/platform-core/*": ["../../packages/platform-core/dist/*"],
      "@acme/ui": ["../../packages/ui/dist/index.d.ts"],
      "@acme/ui/*": ["../../packages/ui/dist/*"],
      "@acme/i18n": ["../../packages/i18n/dist/index.d.ts"],
      "@acme/i18n/*": ["../../packages/i18n/dist/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "cypress/**/*.ts",
    "cypress.config.ts"
  ],
  "exclude": ["node_modules", "functions", ".next", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "**/__mocks__/**", "**/test-utils/**"]
}
