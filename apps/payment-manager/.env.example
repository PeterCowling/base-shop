# ============================================================
# Payment Manager — environment variable reference
# Copy to .env.local and fill in values for local development.
# Never commit real secrets.
# ============================================================

# Session signing secret (min 32 chars in production)
PAYMENT_MANAGER_SESSION_SECRET=

# Admin bearer token for protected UI access (min 32 chars in production)
PAYMENT_MANAGER_ADMIN_TOKEN=

# Comma-separated list of allowed client IPs (deny-all when unset or empty)
PAYMENT_MANAGER_ALLOWED_IPS=127.0.0.1,::1

# Trust proxy headers (cf-connecting-ip / x-forwarded-for) for real client IP
PAYMENT_MANAGER_TRUST_PROXY_IP_HEADERS=true

# AES-256-GCM encryption key for provider credentials (32 bytes, base64-encoded)
# Generate with: openssl rand -base64 32
PAYMENT_MANAGER_ENCRYPTION_KEY=

# Neon PostgreSQL connection string
# Format: postgresql://user:pass@<project>.neon.tech/<dbname>?sslmode=require
# In production, set via: wrangler secret put DATABASE_URL
DATABASE_URL=

# Internal token used by payment-manager when calling Caryina's internal routes
CARYINA_INTERNAL_TOKEN=

# Token that Caryina uses when calling PM's /api/refunds route (Phase 2 dual-write)
CARYINA_PM_TOKEN=

# Internal token used by other trusted services to call payment-manager APIs
PAYMENT_MANAGER_INTERNAL_TOKEN=
