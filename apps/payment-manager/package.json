{
  "name": "@acme/payment-manager",
  "private": true,
  "scripts": {
    "dev": "bash ../../scripts/dev/run-next-app.sh --port 3025 -- --webpack",
    "build": "next build --webpack",
    "build:worker": "opennextjs-cloudflare build",
    "start": "next start -p 3025",
    "lint": "eslint --cache --cache-location .eslintcache src",
    "typecheck": "bash ../../scripts/dev/run-next-app.sh --mode typecheck --port 3025 -- pnpm exec tsc -p tsconfig.json --noEmit --incremental --tsBuildInfoFile .typecheck.tsbuildinfo",
    "test": "bash ../../scripts/tests/run-governed-test.sh -- jest -- --config ./jest.config.cjs"
  },
  "dependencies": {
    "@acme/next-config": "workspace:*",
    "@acme/platform-core": "workspace:*",
    "@acme/stripe": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@themes/base": "workspace:*",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@opennextjs/cloudflare": "^1",
    "typescript": "^5"
  }
}
