# ============================================================
# Inventory Uploader — environment variable reference
# Copy to .env.local and fill in values for local development.
# Never commit real secrets.
# ============================================================

# Session signing secret (min 32 chars in production)
INVENTORY_SESSION_SECRET=

# Admin bearer token for protected API routes (min 32 chars in production)
INVENTORY_ADMIN_TOKEN=

# Comma-separated list of allowed client IPs (deny-all when unset or empty)
INVENTORY_ALLOWED_IPS=127.0.0.1,::1

# Trust proxy headers (cf-connecting-ip / x-forwarded-for) for real client IP
INVENTORY_TRUST_PROXY_IP_HEADERS=true

# Neon PostgreSQL connection string (required when INVENTORY_BACKEND=prisma)
# Format: postgresql://user:pass@<project>.neon.tech/<dbname>?sslmode=require
# In production, set via: wrangler secret put DATABASE_URL
DATABASE_URL=

# Use json for local dev (no Neon needed), prisma for production
INVENTORY_BACKEND=json
