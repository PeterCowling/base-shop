{
  "name": "@apps/cover-me-pretty",
  "private": true,
  "scripts": {
    "pretypecheck": "pnpm --filter @acme/editorial exec tsc -b --force",
    "dev": "bash ../../scripts/dev/run-next-app.sh --port 3004 -- --webpack",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build --webpack",
    "start": "next start -p 3004",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location .eslintcache --max-warnings=0",
    "typecheck": "bash ../../scripts/dev/run-next-app.sh --mode typecheck --port 3004 -- pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec jest --ci --runInBand --detectOpenHandles --config ../../jest.config.cjs"
  },
  "dependencies": {
    "@acme/cms-ui": "workspace:*",
    "@acme/config": "workspace:*",
    "@acme/date-utils": "workspace:*",
    "@acme/design-system": "workspace:*",
    "@acme/editorial": "workspace:*",
    "@acme/email": "workspace:*",
    "@acme/i18n": "workspace:*",
    "@acme/lib": "workspace:*",
    "@acme/next-config": "workspace:*",
    "@acme/page-builder-core": "workspace:*",
    "@acme/sanity": "workspace:*",
    "@acme/seo": "workspace:*",
    "@acme/stripe": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/template-app": "workspace:*",
    "@acme/zod-utils": "workspace:^",
    "@themes/base": "workspace:*",
    "aws4fetch": "^1.0.20",
    "qrcode": "^1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "next": "^16.1.6"
  }
}
